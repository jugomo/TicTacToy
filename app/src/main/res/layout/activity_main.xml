<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.site11.jugomo.tictactoy.MainActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="background"
        android:scaleType="centerCrop"
        android:src="@drawable/tablero" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="6"
            android:text="@string/title"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/buttonsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvTitle"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btMode"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/reset_button_bg"
                android:onClick="modeToggleClick"
                android:text="@string/mode_vs_ia"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btReset"
                android:layout_width="130dp"
                android:layout_height="44dp"
                android:background="@drawable/reset_button_bg"
                android:onClick="resetAction"
                android:text="@string/btn_reset"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/difficultyLayout"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/buttonsRow"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <SeekBar
                android:id="@+id/seekDifficulty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="2"
                android:progress="0"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:shadowColor="#000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:text="@string/difficulty_easy"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:shadowColor="#000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:text="@string/difficulty_medium"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:shadowColor="#000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:text="@string/difficulty_hard"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TableLayout
            android:id="@+id/grid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:layout_marginBottom="4dp">

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="1"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="2"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="3"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:layout_marginBottom="4dp">

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="4"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="5"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt6"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="6"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt7"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="7"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt8"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="8"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/cell_size"
                    android:layout_height="@dimen/cell_size"
                    android:layout_margin="4dp"
                    android:background="@drawable/cell_button_bg"
                    android:clipToOutline="true">
                    <ImageButton
                        android:id="@+id/bt9"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:contentDescription="9"
                        android:onClick="btClick"
                        android:scaleType="centerCrop"
                        android:src="@null" />
                </FrameLayout>

            </TableRow>
        </TableLayout>

        <LinearLayout
            android:id="@+id/thinkingLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/grid"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvHourglass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="@string/thinking"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="italic" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="28dp"
            android:background="#88000000"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:text="@string/msg_welcome"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

    </RelativeLayout>

</FrameLayout>
